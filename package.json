{
  "name": "tether-erp",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter tether-erp-frontend dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter tether-erp-frontend build",
    "start": "pnpm --filter tether-erp-frontend start",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "clean": "pnpm -r exec rm -rf node_modules .next && rm -rf node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.11",
      "@types/react-dom": "19.2.3"
    }
  }
}
