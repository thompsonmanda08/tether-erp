# ============================================================
# Tether-ERP Backend — Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Option A: Individual connection params
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=tether-erp
DB_SSL_MODE=disable       # disable | require | verify-full

# Option B: Single DATABASE_URL (takes precedence if set)
# DATABASE_URL=postgresql://postgres:changeme@localhost:5432/tether-erp?sslmode=disable

# ── Application ───────────────────────────────────────────────
APP_PORT=8080
APP_ENV=development       # development | production

# ── Security ─────────────────────────────────────────────────
# REQUIRED in production — minimum 32 random characters
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error
LOG_OUTPUT=stdout         # stdout | file | both
LOG_FILE=/var/log/tether-erp.log

# ── Redis (optional — for caching) ───────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Email (optional — for notifications) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@your-domain.com

# ── Feature Flags ────────────────────────────────────────────
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOG=true
ENABLE_BUDGET_CONSTRAINTS=true

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT=100
